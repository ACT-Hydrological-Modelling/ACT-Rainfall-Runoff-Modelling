# pyrrm-gui Environment Configuration
# Copy this file to .env and modify as needed

# Database
DATABASE_URL=sqlite:///./data/pyrrm.db

# Redis (for Celery and WebSocket)
REDIS_URL=redis://localhost:6379/0

# Application
DEBUG=false
APP_NAME=pyrrm-gui
APP_VERSION=0.1.0

# Calibration defaults
DEFAULT_WARMUP_DAYS=365
DEFAULT_MAX_EVALS=50000
MAX_CONCURRENT_CALIBRATIONS=2

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
